--[[
	Foam Padding Minigame  (grid fitting — RE4 inventory style)

	A mold cavity is displayed on the grid. Click a piece in the bottom tray to
	select it, then click a grid cell to place it. Pieces can be lifted back off
	the grid and rearranged — getting stuck means rethinking the layout.

	Press R (or the ↻ button) to rotate the selected piece.

	The mold is generated by pre-placing the solution pieces, guaranteeing
	the puzzle is always solvable.

	config = { fragile = bool, toolBonus = number, params = overrides }
	Result = "Fail" | "Pass" | "Good" | "Perfect"
]]

local RunService        = game:GetService("RunService")
local UserInputService  = game:GetService("UserInputService")
local TweenService      = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local GameConfig        = require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("GameConfig"))
local SFX               = require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("SFXPlayer"))

local cfg = GameConfig.FoamPadding

-- ── Module state ──────────────────────────────────────────────────────────
local _result      = "Pass"
local _connections = {}
local _instances   = {}
local _done        = nil
local _finished    = false

local function disconnect()
	for _, c in ipairs(_connections) do c:Disconnect() end
	_connections = {}
end

-- ── Grid constants ────────────────────────────────────────────────────────
local GRID_COLS  = 8
local GRID_ROWS  = 6
local THUMB_CELL = 20   -- px per cell in tray thumbnails

-- ── Piece definitions ─────────────────────────────────────────────────────
local PIECE_DEFS = {
	{ cells = {{0,0},{0,1},{0,2},{0,3}},      color = Color3.fromRGB( 75, 195, 215) }, -- I-4
	{ cells = {{0,0},{1,0},{2,0},{2,1}},      color = Color3.fromRGB(220, 140,  45) }, -- L
	{ cells = {{0,1},{1,1},{2,0},{2,1}},      color = Color3.fromRGB( 70, 115, 215) }, -- J
	{ cells = {{0,0},{0,1},{0,2},{1,1}},      color = Color3.fromRGB(175,  75, 210) }, -- T
	{ cells = {{0,1},{0,2},{1,0},{1,1}},      color = Color3.fromRGB( 80, 190,  90) }, -- S
	{ cells = {{0,0},{0,1},{1,1},{1,2}},      color = Color3.fromRGB(215,  70,  70) }, -- Z
	{ cells = {{0,0},{0,1},{1,0},{1,1}},      color = Color3.fromRGB(215, 190,  55) }, -- O
	{ cells = {{0,0},{0,1},{0,2}},            color = Color3.fromRGB( 55, 200, 165) }, -- I-3
	{ cells = {{0,0},{1,0},{1,1}},            color = Color3.fromRGB(215, 110, 160) }, -- Γ
	{ cells = {{0,1},{1,0},{1,1}},            color = Color3.fromRGB(150, 200,  75) }, -- Γ-mir
}

-- ── Colours ───────────────────────────────────────────────────────────────
local COL_GOLD       = Color3.fromRGB(210, 170,  60)
local COL_WHITE      = Color3.fromRGB(255, 255, 255)
local COL_WARN       = Color3.fromRGB(230, 170,  50)
local COL_HUD_BG     = Color3.fromRGB( 20,  16,  30)
local COL_DANGER     = Color3.fromRGB(220,  80,  80)
local COL_CANVAS     = Color3.fromRGB( 28,  20,  42)
local COL_MOLD_EMPTY = Color3.fromRGB( 58,  44,  82)
local COL_MOLD_BRD   = Color3.fromRGB(115,  90, 160)
local COL_VOID_BG    = Color3.fromRGB( 16,  10,  24)
local COL_GHOST_OK   = Color3.fromRGB( 80, 215, 105)
local COL_GHOST_BAD  = Color3.fromRGB(215,  55,  55)
local COL_SEL_BORDER = Color3.fromRGB(255, 255, 255)
local COL_TRAY_BG    = Color3.fromRGB( 20,  14,  34)
local COL_CARD_BG    = Color3.fromRGB( 42,  32,  64)

-- ── Piece utilities ───────────────────────────────────────────────────────

local function copyCells(cells)
	local t = {}
	for _, c in ipairs(cells) do t[#t + 1] = {c[1], c[2]} end
	return t
end

local function rotateCW(cells)
	local t = {}
	for _, c in ipairs(cells) do t[#t + 1] = {c[2], -c[1]} end
	local minR, minC = math.huge, math.huge
	for _, c in ipairs(t) do
		if c[1] < minR then minR = c[1] end
		if c[2] < minC then minC = c[2] end
	end
	for _, c in ipairs(t) do c[1] = c[1] - minR; c[2] = c[2] - minC end
	return t
end

local function cellBounds(cells)
	local maxR, maxC = 0, 0
	for _, c in ipairs(cells) do
		if c[1] > maxR then maxR = c[1] end
		if c[2] > maxC then maxC = c[2] end
	end
	return maxR + 1, maxC + 1
end

-- ── Mold generation ───────────────────────────────────────────────────────
-- Pieces 2+ are placed adjacent to existing mold cells so the mold forms one
-- connected region rather than scattered islands. Fallback to random placement
-- if no connected spot is found after exhausting all border/rotation combos.
local function generateMold(pieceCount)
	local grid = {}
	for r = 1, GRID_ROWS do
		grid[r] = {}
		for c = 1, GRID_COLS do grid[r][c] = 0 end
	end

	local indices = {}
	for i = 1, #PIECE_DEFS do indices[i] = i end
	for i = #indices, 2, -1 do
		local j = math.random(i); indices[i], indices[j] = indices[j], indices[i]
	end

	local function canPlace(cells, or_, oc)
		for _, c in ipairs(cells) do
			local r2, c2 = c[1] + or_, c[2] + oc
			if r2 < 1 or r2 > GRID_ROWS or c2 < 1 or c2 > GRID_COLS or grid[r2][c2] ~= 0 then
				return false
			end
		end
		return true
	end

	local function doPlace(cells, or_, oc, idx)
		for _, c in ipairs(cells) do grid[c[1] + or_][c[2] + oc] = idx end
	end

	-- Returns all empty cells that border at least one filled mold cell, shuffled.
	local function getBorderCells()
		local out, seen = {}, {}
		for r = 1, GRID_ROWS do
			for c = 1, GRID_COLS do
				if grid[r][c] ~= 0 then
					for _, d in ipairs({ {-1,0},{1,0},{0,-1},{0,1} }) do
						local nr, nc = r + d[1], c + d[2]
						local key = nr * 100 + nc
						if nr >= 1 and nr <= GRID_ROWS and nc >= 1 and nc <= GRID_COLS
						   and grid[nr][nc] == 0 and not seen[key] then
							out[#out + 1] = {nr, nc}
							seen[key] = true
						end
					end
				end
			end
		end
		for bi = #out, 2, -1 do
			local j = math.random(bi); out[bi], out[j] = out[j], out[bi]
		end
		return out
	end

	local placed = {}

	for i = 1, pieceCount do
		local defIdx = indices[i]
		local pd     = PIECE_DEFS[defIdx]
		local ok     = false

		-- For pieces 2+, try each border cell × each rotation × each cell as anchor.
		-- This guarantees the new piece touches the existing mold (connected shape).
		if #placed > 0 then
			local border = getBorderCells()
			for _, bpos in ipairs(border) do
				if ok then break end
				local br, bc = bpos[1], bpos[2]
				local cells = copyCells(pd.cells)
				for _ = 0, 3 do
					if ok then break end
					for _, anchor in ipairs(cells) do
						local or_, oc = br - anchor[1], bc - anchor[2]
						if canPlace(cells, or_, oc) then
							doPlace(cells, or_, oc, i)
							placed[#placed + 1] = { defIdx=defIdx, cells=cells, color=pd.color }
							ok = true
							break
						end
					end
					cells = rotateCW(cells)
				end
			end
		end

		-- Fallback: fully random placement (also used for the very first piece).
		if not ok then
			for _ = 1, 100 do
				local cells = copyCells(pd.cells)
				for _ = 1, math.random(0, 3) do cells = rotateCW(cells) end
				local h, w = cellBounds(cells)
				local or_ = math.random(1, math.max(1, GRID_ROWS - h + 1))
				local oc  = math.random(1, math.max(1, GRID_COLS - w + 1))
				if canPlace(cells, or_, oc) then
					doPlace(cells, or_, oc, i)
					placed[#placed + 1] = { defIdx=defIdx, cells=cells, color=pd.color }
					ok = true; break
				end
			end
			if not ok then
				warn("[FoamPadding] Couldn't fit piece", i, "— puzzle has fewer pieces than requested")
			end
		end
	end

	return grid, placed
end

-- ── Public interface ──────────────────────────────────────────────────────
local FoamPadding = {}

function FoamPadding.Start(container, config)
	_result      = "Pass"
	_connections = {}
	_instances   = {}
	_done        = Instance.new("BindableEvent")
	_finished    = false

	local p          = config.params or cfg
	local timeLimit  = p.timeLimit
	local pieceCount = p.pieceCount

	local function addFoamTexture(frame, zIndex, initialTransp)
		local img = Instance.new("ImageLabel")
		img.Size                   = UDim2.fromScale(1, 1)
		img.BackgroundTransparency = 1
		img.Image                  = ""
		img.ImageTransparency      = initialTransp ~= nil and initialTransp or 0.55
		img.BorderSizePixel        = 0
		img.ZIndex                 = zIndex
		img.Parent                 = frame
		return img
	end

	local mold, pieceDefs = generateMold(pieceCount)
	local actualCount = #pieceDefs

	local totalMoldCells = 0
	for r = 1, GRID_ROWS do
		for c = 1, GRID_COLS do
			if mold[r][c] ~= 0 then totalMoldCells = totalMoldCells + 1 end
		end
	end

	local playerGrid = {}
	for r = 1, GRID_ROWS do
		playerGrid[r] = {}
		for c = 1, GRID_COLS do playerGrid[r][c] = 0 end
	end
	local filledCells = 0

	local pieceState = {}
	for i, pd in ipairs(pieceDefs) do
		-- Randomise the starting rotation so players can't rely on muscle memory
		local cells = copyCells(pd.cells)
		for _ = 1, math.random(0, 3) do cells = rotateCW(cells) end
		pieceState[i] = { cells = cells, color = pd.color, placed = false }
	end

	-- ── Canvas ────────────────────────────────────────────────────────────

	local canvas = Instance.new("Frame")
	canvas.Name = "Canvas"
	canvas.Size = UDim2.new(0.90, 0, 0.80, 0)
	canvas.AnchorPoint = Vector2.new(0.5, 0.5)
	canvas.Position = UDim2.fromScale(0.5, 0.60)
	canvas.BackgroundColor3 = COL_CANVAS
	canvas.BackgroundTransparency = 0.18
	canvas.BorderSizePixel = 0
	canvas.ClipsDescendants = false
	canvas.ZIndex           = 2
	canvas.Parent = container
	table.insert(_instances, canvas)
	Instance.new("UICorner", canvas).CornerRadius = UDim.new(0, 14)

	local canvasStroke = Instance.new("UIStroke")
	canvasStroke.Color = Color3.fromRGB(72, 54, 108)
	canvasStroke.Thickness = 1.5
	canvasStroke.Transparency = 0.4
	canvasStroke.Parent = canvas

	task.wait()   -- let AbsoluteSize populate

	local cvW = canvas.AbsoluteSize.X
	local cvH = canvas.AbsoluteSize.Y

	-- Layout fractions
	local TRAY_H_FRAC = 0.22
	local TRAY_GAP    = 8
	local SIDE_PAD    = 12
	local TOP_PAD     = 8

	-- ── Compact centered HUD pill (in container, above canvas) ────────────

	local hudBar = Instance.new("Frame")
	hudBar.Size                   = UDim2.new(0.62, 0, 0, 40)
	hudBar.AnchorPoint            = Vector2.new(0.5, 0)
	hudBar.Position               = UDim2.new(0.5, 0, 0, 140)
	hudBar.BackgroundColor3       = COL_HUD_BG
	hudBar.BackgroundTransparency = 0.18
	hudBar.BorderSizePixel        = 0
	hudBar.Parent                 = container
	table.insert(_instances, hudBar)
	Instance.new("UICorner", hudBar).CornerRadius = UDim.new(0, 10)

	local timerLabel = Instance.new("TextLabel")
	timerLabel.Size                   = UDim2.new(0, 48, 1, 0)
	timerLabel.Position               = UDim2.new(0, 10, 0, 0)
	timerLabel.BackgroundTransparency = 1
	timerLabel.Text                   = tostring(timeLimit)
	timerLabel.TextColor3             = COL_WHITE
	timerLabel.Font                   = Enum.Font.GothamBold
	timerLabel.TextSize               = 19
	timerLabel.TextXAlignment         = Enum.TextXAlignment.Center
	timerLabel.Parent                 = hudBar

	local timerTrack = Instance.new("Frame")
	timerTrack.Size               = UDim2.new(1, -142, 0, 7)
	timerTrack.Position           = UDim2.new(0, 66, 0.5, -3)
	timerTrack.BackgroundColor3   = Color3.fromRGB(45, 40, 60)
	timerTrack.BackgroundTransparency = 0
	timerTrack.BorderSizePixel    = 0
	timerTrack.Parent             = hudBar
	Instance.new("UICorner", timerTrack).CornerRadius = UDim.new(0, 3)

	local timerBar = Instance.new("Frame")
	timerBar.Size               = UDim2.fromScale(1, 1)
	timerBar.BackgroundColor3   = COL_WHITE
	timerBar.BorderSizePixel    = 0
	timerBar.Parent             = timerTrack
	Instance.new("UICorner", timerBar).CornerRadius = UDim.new(0, 3)

	local progLabel = Instance.new("TextLabel")
	progLabel.Size                   = UDim2.new(0, 64, 1, 0)
	progLabel.AnchorPoint            = Vector2.new(1, 0)
	progLabel.Position               = UDim2.new(1, -8, 0, 0)
	progLabel.BackgroundTransparency = 1
	progLabel.Text                   = "0 / " .. totalMoldCells
	progLabel.TextColor3             = COL_GOLD
	progLabel.Font                   = Enum.Font.GothamBold
	progLabel.TextSize               = 18
	progLabel.TextXAlignment         = Enum.TextXAlignment.Center
	progLabel.Parent                 = hudBar

	local trayPxH   = math.floor(cvH * TRAY_H_FRAC)
	local gridAreaH = cvH - trayPxH - TRAY_GAP - TOP_PAD
	local gridAreaW = cvW - SIDE_PAD * 2

	local cellSize = math.floor(math.min(gridAreaW / GRID_COLS, gridAreaH / GRID_ROWS))
	local gridPxW  = cellSize * GRID_COLS
	local gridPxH  = cellSize * GRID_ROWS

	-- ── Grid container ────────────────────────────────────────────────────

	local gridContainer = Instance.new("Frame")
	gridContainer.Name = "GridContainer"
	gridContainer.Size = UDim2.fromOffset(gridPxW, gridPxH)
	gridContainer.AnchorPoint = Vector2.new(0.5, 0)
	gridContainer.Position = UDim2.fromOffset(cvW / 2, TOP_PAD)
	gridContainer.BackgroundTransparency = 1
	gridContainer.BorderSizePixel = 0
	gridContainer.ZIndex = 2
	gridContainer.Parent = canvas
	table.insert(_instances, gridContainer)

	-- ── Cell frames ───────────────────────────────────────────────────────

	local cellFrames   = {}
	local cellTextures = {}   -- foam overlay per mold cell; hidden until a piece is placed
	for r = 1, GRID_ROWS do
		cellFrames[r]   = {}
		cellTextures[r] = {}
		for c = 1, GRID_COLS do
			local isMold = mold[r][c] ~= 0
			local cell = Instance.new("Frame")
			cell.Size = UDim2.fromOffset(cellSize - 2, cellSize - 2)
			cell.Position = UDim2.fromOffset((c - 1) * cellSize + 1, (r - 1) * cellSize + 1)
			cell.BackgroundColor3 = isMold and COL_MOLD_EMPTY or COL_VOID_BG
			cell.BackgroundTransparency = isMold and 0 or 0.70
			cell.BorderSizePixel = 0
			cell.ZIndex = 2
			cell.Parent = gridContainer
			if isMold then
				local stroke = Instance.new("UIStroke")
				stroke.Color = COL_MOLD_BRD
				stroke.Thickness = 1
				stroke.Transparency = 0.3
				stroke.Parent = cell
				cellTextures[r][c] = addFoamTexture(cell, 3, 1)  -- hidden until placed
			end
			Instance.new("UICorner", cell).CornerRadius = UDim.new(0, 4)
			cellFrames[r][c] = cell
		end
	end

	-- ── Piece tray ────────────────────────────────────────────────────────

	local tray = Instance.new("Frame")
	tray.Name = "Tray"
	tray.Size = UDim2.fromOffset(cvW - SIDE_PAD * 2, trayPxH - 4)
	tray.AnchorPoint = Vector2.new(0.5, 1)
	tray.Position = UDim2.fromOffset(cvW / 2, cvH - 4)
	tray.BackgroundColor3 = COL_TRAY_BG
	tray.BackgroundTransparency = 0.45
	tray.BorderSizePixel = 0
	tray.ZIndex = 5
	tray.Parent = canvas
	table.insert(_instances, tray)
	Instance.new("UICorner", tray).CornerRadius = UDim.new(0, 10)

	local trayStroke = Instance.new("UIStroke")
	trayStroke.Color = Color3.fromRGB(72, 54, 108)
	trayStroke.Thickness = 1
	trayStroke.Transparency = 0.5
	trayStroke.Parent = tray

	local trayLayout = Instance.new("UIListLayout")
	trayLayout.FillDirection = Enum.FillDirection.Horizontal
	trayLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	trayLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	trayLayout.Padding = UDim.new(0, 10)
	trayLayout.Parent = tray

	-- ── Tray cards ────────────────────────────────────────────────────────
	-- Card width = 4 thumb cells + 24px padding. Height = tray height - 12px.

	local CARD_W     = 4 * THUMB_CELL + 26
	local CARD_H     = trayPxH - 16
	local trayCards  = {}
	local cardStrokes = {}   -- UIStroke per card for selection highlight

	local function drawThumb(card, cells, color)
		local old = card:FindFirstChild("ThumbInner")
		if old then old:Destroy() end
		local h, w = cellBounds(cells)
		local inner = Instance.new("Frame")
		inner.Name = "ThumbInner"
		inner.Size = UDim2.fromOffset(w * THUMB_CELL, h * THUMB_CELL)
		inner.AnchorPoint = Vector2.new(0.5, 0.5)
		inner.Position = UDim2.fromScale(0.5, 0.46)
		inner.BackgroundTransparency = 1
		inner.BorderSizePixel = 0
		inner.ZIndex = 7
		inner.Parent = card
		for _, c in ipairs(cells) do
			local sq = Instance.new("Frame")
			sq.Size = UDim2.fromOffset(THUMB_CELL - 2, THUMB_CELL - 2)
			sq.Position = UDim2.fromOffset(c[2] * THUMB_CELL + 1, c[1] * THUMB_CELL + 1)
			sq.BackgroundColor3 = color
			sq.BorderSizePixel = 0
			sq.ZIndex = 8
			sq.Parent = inner
			Instance.new("UICorner", sq).CornerRadius = UDim.new(0, 3)
			addFoamTexture(sq, 9)
		end
	end

	for i = 1, actualCount do
		local ps   = pieceState[i]
		local card = Instance.new("Frame")
		card.Name = "Card_" .. i
		card.Size = UDim2.fromOffset(CARD_W, CARD_H)
		card.BackgroundColor3 = COL_CARD_BG
		card.BackgroundTransparency = 0.35
		card.BorderSizePixel = 0
		card.ZIndex = 6
		card.Parent = tray
		Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)

		-- Piece number badge (top-left)
		local badge = Instance.new("TextLabel")
		badge.Size = UDim2.fromOffset(18, 18)
		badge.Position = UDim2.fromOffset(5, 4)
		badge.BackgroundTransparency = 1
		badge.Text = tostring(i)
		badge.TextColor3 = Color3.fromRGB(140, 120, 180)
		badge.Font = Enum.Font.GothamBold
		badge.TextSize = 11
		badge.ZIndex = 9
		badge.Parent = card

		-- Selection stroke (hidden by default)
		local stroke = Instance.new("UIStroke")
		stroke.Color = COL_SEL_BORDER
		stroke.Thickness = 2.5
		stroke.Transparency = 1    -- invisible until selected
		stroke.Parent = card
		cardStrokes[i] = stroke

		-- Piece art
		drawThumb(card, ps.cells, ps.color)

		-- Rotate button (bottom-right)
		local rotBtn = Instance.new("TextButton")
		rotBtn.Name = "RotBtn"
		rotBtn.Size = UDim2.fromOffset(28, 24)
		rotBtn.AnchorPoint = Vector2.new(1, 1)
		rotBtn.Position = UDim2.new(1, -4, 1, -4)
		rotBtn.BackgroundColor3 = Color3.fromRGB(18, 12, 30)
		rotBtn.TextColor3 = COL_GOLD
		rotBtn.Font = Enum.Font.GothamBold
		rotBtn.TextSize = 15
		rotBtn.Text = "↻"
		rotBtn.BorderSizePixel = 0
		rotBtn.ZIndex = 9
		rotBtn.Parent = card
		Instance.new("UICorner", rotBtn).CornerRadius = UDim.new(0, 5)

		trayCards[i] = card
	end

	-- R key hint label inside tray (right side)
	local hintLabel = Instance.new("TextLabel")
	hintLabel.Size = UDim2.fromOffset(90, 24)
	hintLabel.AnchorPoint = Vector2.new(1, 1)
	hintLabel.Position = UDim2.new(1, -8, 1, -6)
	hintLabel.BackgroundTransparency = 1
	hintLabel.Text = "[RMB] rotate"
	hintLabel.TextColor3 = Color3.fromRGB(100, 85, 130)
	hintLabel.Font = Enum.Font.Gotham
	hintLabel.TextSize = 11
	hintLabel.TextXAlignment = Enum.TextXAlignment.Right
	hintLabel.ZIndex = 6
	hintLabel.Parent = tray

	-- ── Game state helpers ────────────────────────────────────────────────

	local selectedPiece = nil

	local function restoreCell(r, c)
		local cell = cellFrames[r][c]
		local tex  = cellTextures[r] and cellTextures[r][c]
		if playerGrid[r][c] ~= 0 then
			cell.BackgroundColor3 = pieceState[playerGrid[r][c]].color
			cell.BackgroundTransparency = 0.05
			if tex then tex.ImageTransparency = 0.55 end
		elseif mold[r][c] ~= 0 then
			cell.BackgroundColor3 = COL_MOLD_EMPTY
			cell.BackgroundTransparency = 0
			if tex then tex.ImageTransparency = 1 end
		else
			cell.BackgroundColor3 = COL_VOID_BG
			cell.BackgroundTransparency = 0.70
		end
	end

	local ghostPos = {}
	local function clearGhost()
		for _, pos in ipairs(ghostPos) do restoreCell(pos[1], pos[2]) end
		ghostPos = {}
	end

	local function isValidPlacement(cells, or_, oc)
		for _, c in ipairs(cells) do
			local r2, c2 = c[1] + or_, c[2] + oc
			if r2 < 1 or r2 > GRID_ROWS or c2 < 1 or c2 > GRID_COLS then return false end
			if mold[r2][c2] == 0 then return false end
			if playerGrid[r2][c2] ~= 0 then return false end
		end
		return true
	end

	local function showGhost(cells, or_, oc)
		clearGhost()
		local valid = isValidPlacement(cells, or_, oc)
		local col   = valid and COL_GHOST_OK or COL_GHOST_BAD
		for _, c in ipairs(cells) do
			local r2, c2 = c[1] + or_, c[2] + oc
			if r2 >= 1 and r2 <= GRID_ROWS and c2 >= 1 and c2 <= GRID_COLS then
				cellFrames[r2][c2].BackgroundColor3 = col
				cellFrames[r2][c2].BackgroundTransparency = 0.22
				ghostPos[#ghostPos + 1] = {r2, c2}
			end
		end
		return valid
	end

	-- Returns the top-left anchor so the piece is centered on the hovered cell.
	local function getAnchor(cells, mouseRow, mouseCol)
		local h, w = cellBounds(cells)
		return mouseRow - math.floor(h / 2), mouseCol - math.floor(w / 2)
	end

	local function setSelected(idx)
		-- Clear old selection highlight
		if selectedPiece and cardStrokes[selectedPiece] then
			TweenService:Create(cardStrokes[selectedPiece],
				TweenInfo.new(0.12), { Transparency = 1 }):Play()
		end
		selectedPiece = idx
		if idx and cardStrokes[idx] then
			TweenService:Create(cardStrokes[idx],
				TweenInfo.new(0.12), { Transparency = 0 }):Play()
		end
		if not idx then clearGhost() end
	end

	local finishGame  -- forward decl

	local function placePiece(idx, or_, oc)
		local ps = pieceState[idx]
		for _, c in ipairs(ps.cells) do
			local r2, c2 = c[1] + or_, c[2] + oc
			playerGrid[r2][c2] = idx
			cellFrames[r2][c2].BackgroundColor3 = ps.color
			cellFrames[r2][c2].BackgroundTransparency = 0.05
			local tex = cellTextures[r2] and cellTextures[r2][c2]
			if tex then tex.ImageTransparency = 0.55 end
		end
		ps.placed   = true
		filledCells = filledCells + #ps.cells
		progLabel.Text = filledCells .. " / " .. totalMoldCells
		TweenService:Create(progLabel, TweenInfo.new(0.07), { TextSize = 24 }):Play()
		task.delay(0.09, function()
			TweenService:Create(progLabel, TweenInfo.new(0.18, Enum.EasingStyle.Back), { TextSize = 18 }):Play()
		end)
		SFX.Play("FoamSnap")

		-- Dim the card
		local card = trayCards[idx]
		if card then
			TweenService:Create(card, TweenInfo.new(0.15), { BackgroundTransparency = 0.75 }):Play()
		end
		setSelected(nil)

		if filledCells >= totalMoldCells then task.delay(0.2, finishGame) end
	end

	local function liftPiece(idx)
		SFX.Play("FoamLift")
		-- Remove from grid
		local count = 0
		for r = 1, GRID_ROWS do
			for c = 1, GRID_COLS do
				if playerGrid[r][c] == idx then
					count = count + 1
					playerGrid[r][c] = 0
					restoreCell(r, c)
				end
			end
		end
		pieceState[idx].placed = false
		filledCells = filledCells - count
		progLabel.Text = filledCells .. " / " .. totalMoldCells

		-- Restore card brightness
		local card = trayCards[idx]
		if card then
			TweenService:Create(card, TweenInfo.new(0.15), { BackgroundTransparency = 0.35 }):Play()
		end
		setSelected(idx)
	end

	local function rotatePiece(idx)
		if not idx then return end
		if pieceState[idx].placed then return end
		SFX.Play("FoamRotate")
		pieceState[idx].cells = rotateCW(pieceState[idx].cells)
		drawThumb(trayCards[idx], pieceState[idx].cells, pieceState[idx].color)
	end

	-- ── Tray card interactions ────────────────────────────────────────────

	for i = 1, actualCount do
		local idx  = i
		local card = trayCards[i]

		-- Click card → select / deselect
		local cardConn = card.InputBegan:Connect(function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton1
				and input.UserInputType ~= Enum.UserInputType.Touch then return end
			if pieceState[idx].placed then
				-- already placed: lift it back up
				liftPiece(idx)
				return
			end
			if selectedPiece == idx then
				setSelected(nil)
			else
				setSelected(idx)
			end
		end)
		table.insert(_connections, cardConn)

		-- Rotate button
		local rotBtn = card:FindFirstChild("RotBtn")
		if rotBtn then
			local rotConn = rotBtn.Activated:Connect(function()
				if pieceState[idx].placed then return end
				rotatePiece(idx)
				-- Ensure selection is on this piece so ghost updates next move
				if selectedPiece ~= idx then setSelected(idx) end
			end)
			table.insert(_connections, rotConn)
		end
	end

	-- ── Grid interaction ──────────────────────────────────────────────────

	-- Last hovered cell (used to refresh ghost after rotation)
	local lastMouseR, lastMouseC = nil, nil

	-- Per-cell connections: Roblox handles all hit-testing — no coordinate math.
	for r = 1, GRID_ROWS do
		for c = 1, GRID_COLS do
			local row, col = r, c

			-- Ghost preview: fires when mouse enters this cell
			local enterConn = cellFrames[r][c].MouseEnter:Connect(function()
				if not selectedPiece then return end
				lastMouseR, lastMouseC = row, col
				local or_, oc = getAnchor(pieceState[selectedPiece].cells, row, col)
				showGhost(pieceState[selectedPiece].cells, or_, oc)
			end)
			table.insert(_connections, enterConn)

			-- Click: LMB = place/lift, RMB = rotate
			local cellConn = cellFrames[r][c].InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton2 then
					if selectedPiece then
						rotatePiece(selectedPiece)
						lastMouseR, lastMouseC = row, col
						local or_, oc = getAnchor(pieceState[selectedPiece].cells, row, col)
						showGhost(pieceState[selectedPiece].cells, or_, oc)
					end
					return
				end
				if input.UserInputType ~= Enum.UserInputType.MouseButton1
					and input.UserInputType ~= Enum.UserInputType.Touch then return end
				if selectedPiece then
					local or_, oc = getAnchor(pieceState[selectedPiece].cells, row, col)
					if isValidPlacement(pieceState[selectedPiece].cells, or_, oc) then
						placePiece(selectedPiece, or_, oc)
					elseif playerGrid[row][col] ~= 0 then
						liftPiece(playerGrid[row][col])
					else
						SFX.Play("FoamMisplace")
					end
				elseif playerGrid[row][col] ~= 0 then
					liftPiece(playerGrid[row][col])
				end
			end)
			table.insert(_connections, cellConn)
		end
	end

	-- Clear ghost when mouse leaves the grid entirely
	local leaveConn = gridContainer.MouseLeave:Connect(function()
		lastMouseR, lastMouseC = nil, nil
		clearGhost()
	end)
	table.insert(_connections, leaveConn)

	-- R key: rotate selected piece (RMB on grid is primary; R is a fallback shortcut)
	local keyConn = UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.KeyCode ~= Enum.KeyCode.R then return end
		if not selectedPiece then return end
		rotatePiece(selectedPiece)
		if lastMouseR then
			local or_, oc = getAnchor(pieceState[selectedPiece].cells, lastMouseR, lastMouseC)
			showGhost(pieceState[selectedPiece].cells, or_, oc)
		end
	end)
	table.insert(_connections, keyConn)

	-- Escape: deselect
	local escConn = UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.KeyCode == Enum.KeyCode.Escape then setSelected(nil) end
	end)
	table.insert(_connections, escConn)

	-- ── Finish / timer ────────────────────────────────────────────────────

	finishGame = function()
		if _finished then return end
		_finished = true
		disconnect()
		local ratio = totalMoldCells > 0 and (filledCells / totalMoldCells) or 0
		if filledCells == 0 then
			_result = "Fail"
		elseif ratio >= p.perfectMinRatio then
			_result = "Perfect"
		elseif ratio >= p.goodMinRatio then
			_result = "Good"
		else
			_result = "Pass"
		end
		if filledCells >= totalMoldCells then SFX.Play("FoamComplete") end
		if _done then _done:Fire() end
	end

	local startClock = os.clock()
	local barConn = RunService.Heartbeat:Connect(function()
		if _finished then return end
		local ratio = math.max(0, 1 - (os.clock() - startClock) / timeLimit)
		timerBar.Size = UDim2.fromScale(ratio, 1)
	end)
	table.insert(_connections, barConn)

	local COL_VIG_YELLOW = Color3.fromRGB(230, 190, 50)
	local COL_VIG_GREEN  = Color3.fromRGB(70,  210, 90)
	local COL_VIG_RED    = Color3.fromRGB(210,  70, 70)

	local vignette = Instance.new("Frame")
	vignette.Size                   = UDim2.fromScale(1, 1)
	vignette.BackgroundColor3       = COL_VIG_YELLOW
	vignette.BackgroundTransparency = 0.88
	vignette.ZIndex                 = 1
	vignette.BorderSizePixel        = 0
	vignette.Parent                 = container
	table.insert(_instances, vignette)

	local vigConn = RunService.Heartbeat:Connect(function()
		if _finished then return end
		local elapsed = math.clamp((os.clock() - startClock) / timeLimit, 0, 1)
		local color
		if elapsed < 0.4 then
			color = COL_VIG_YELLOW:Lerp(COL_VIG_GREEN, elapsed / 0.4)
		elseif elapsed < 0.6 then
			color = COL_VIG_GREEN
		else
			color = COL_VIG_GREEN:Lerp(COL_VIG_RED, (elapsed - 0.6) / 0.4)
		end
		vignette.BackgroundColor3 = color
	end)
	table.insert(_connections, vigConn)

	task.spawn(function()
		local remaining = timeLimit
		while remaining > 0 and not _finished do
			task.wait(1)
			remaining = remaining - 1
			timerLabel.Text = tostring(remaining)
			local ratio = remaining / timeLimit
			local col = ratio > 0.5 and COL_WHITE or ratio > 0.25 and COL_WARN or COL_DANGER
			timerLabel.TextColor3     = col
			timerBar.BackgroundColor3 = col
		end
		if not _finished then finishGame() end
	end)

	_done.Event:Wait()
	_done:Destroy()
	_done = nil
end

function FoamPadding.GetResult()
	return _result
end

function FoamPadding.Cleanup()
	disconnect()
	for _, inst in ipairs(_instances) do
		if inst and inst.Parent then inst:Destroy() end
	end
	_instances = {}
	if _done then _done:Destroy(); _done = nil end
end

function FoamPadding.Cancel()
	_finished = true
	if _done then _done:Fire() end
end

return FoamPadding
